{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/products.json",
      "destination": "/public/products.json"
    }
  ],
  "redirects": [
    {
      "source": "/checkout.html",
      "destination": "/html/checkout.html",
      "permanent": true
    },
    {
      "source": "/favorites.html",
      "destination": "/html/favorites.html",
      "permanent": true
    },
    {
      "source": "/productDetails.html",
      "destination": "/html/productDetails.html",
      "permanent": true
    },
    {
      "source": "/search.html",
      "destination": "/html/search.html",
      "permanent": true
    }
  ]
}